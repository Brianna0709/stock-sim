:::footnote_list
[
  {
    "footnoteNodeId": "7712fec673f040b981f469cadc938cec",
    "nodeId": "b37b993f14ff4a61938284606e1135b7",
    "content": "14.4%：360/2500"
  },
  {
    "footnoteNodeId": "61760ab86f574ac8a1f949e93ab33a8a",
    "nodeId": "654962f54750488cbcb94ec2fcc2b5ea",
    "content": "30%：参考协商退智能回复分流需求的解决率约为 20-40%"
  },
  {
    "footnoteNodeId": "b762990defb1479d84f4e6b812e21d17",
    "nodeId": "a24f91cbeb944d71a044c08755ed6f30",
    "content": "退改人工服务率 = 规则外+规则内人工工单数 / 总支付订单数，初始值25年全年平均1.18%，其中规则外+规则内人工工单数 = 535282单，总支付订单数 = 45214531单"
  },
  {
    "footnoteNodeId": "b39e11195a854b0799a75939ac21d43f",
    "nodeId": "8396c8e77f664f95a69076136033bc54",
    "content": "480：1月份被动总服务率1740，YOY降34.5%。客服被动人工服务率480，YOY降30.6%"
  },
  {
    "footnoteNodeId": "3cc8f8bdea1c43f18a0ad911a866f6ef",
    "nodeId": "32357df5f7ec4e62bc73891c3dad3e28",
    "content": "引导房客邀请房东协商退：目前此场景下不存在房客发起协商退的功能，只能由房东发起协商退"
  },
  {
    "footnoteNodeId": "fa9e31c4589f48b2bb5f9b840c70e4ed",
    "nodeId": "bf62641951504d218fd226f07f160fd9",
    "content": "房东可进一步设置项"
  }
]
