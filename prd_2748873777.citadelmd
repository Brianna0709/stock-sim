      "content": "252人/日，减少进线108人/日\n\n:::collapse{}\n 测算逻辑\n---\nim中提出退款后24小时内又进线客服的总人数360人/日，其中协商退242人/日，剩余为非协商退。按挽回率:[quote]{quoteId=\"2748873777--4bd52afe-fd87-4b3b-a72d-69b0757e3b10\"}30%[/quote]:[footnote]{id=\"a15bebe5-c8b9-4322-a532-2d1267722cc3\" annotate=\"\" nodeId=\"61760ab86f574ac8a1f949e93ab33a8a\"}，预计减少进线108人/日。\n\n:::collapse{}\n点击展开内容\n---\n:::table{borderColor=\"#dddddd\" borderStyle=\"solid\" borderWidth=1 responsive=false}\n[\n  [\n    {\n      \"type\": \"table_header\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          84\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"类型\"\n    },\n    {\n      \"type\": \"table_header\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          513\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"指标\"\n    },\n    {\n      \"type\": \"table_header\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          487\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"口径\"\n    },\n    {\n      \"type\": \"table_header\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          281\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"现状值\"\n    }\n  ],\n  [\n    {\n      \"type\": \"table_header\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 4,\n        \"colwidth\": [\n          84\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"退费退款\"\n    },\n    {\n      \"type\": \"table_cell\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          513\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"IM中提出**退费退款需求**的房客数\\n\\n```Plain Text title=\\\"IM中提出退费退款需求的房客数/日均\\\"\\nWITH pre_filtered AS (\\n    -- 第一步：只拿必要的列，并过滤掉非目标行，减少参与后续匹配的数据量\\n    SELECT \\n        dt,\\n        from_phx_user_id,\\n        msg_payload\\n    FROM ba_phx.phx_mdw_detail_message_sync\\n    WHERE dt BETWEEN '20251215' AND '20260115'\\n      AND is_from_phx_host = 0 \\n      AND is_to_phx_host = 1\\n),\\ndaily_user_flag AS (\\n    -- 第二步：先按天和用户聚合。只要该用户当天发过一条满足条件的信息，就标记为 1\\n    -- 这样可以极大减少后续 AVG 运算的数据条数\\n    SELECT \\n        dt,\\n        from_phx_user_id\\n    FROM pre_filtered\\n    WHERE msg_payload RLIKE '(退款|退费|退钱|全额退|申请退|补差价|赔偿|取消订单|取消预订)'\\n      AND msg_payload NOT LIKE '%协商退款%' \\n    GROUP BY dt, from_phx_user_id\\n)\\n-- 第三步：对已经去重后的结果进行统计\\nSELECT \\n    ROUND(COUNT(1) * 1.0 / COUNT(DISTINCT dt), 2) AS avg_daily_guests\\nFROM daily_user_flag;\\n```\"\n    },\n    {\n      \"type\": \"table_cell\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          487\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"IM中提出退款退费相关，不包含协商退款卡片的标题\\n\\n:::collapse{}\\n口径详细解释\\n---\\n协商退款卡片标题为“我已发起协商退款，请处理”。抽查500条“协商退”关键词，msg payload中只有2条是房客自行提出协商退的内容，其他都是系统发送的卡片/文案\\n\\n因此实际统计的时候，需要减去“协商退款”这个关键词\\n:::\"\n    },\n    {\n      \"type\": \"table_cell\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          281\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"794人/天\"\n    }\n  ],\n  [\n    {\n      \"type\": \"table_cell\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          513\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"IM内提出**退款退费**需求后，**1小时**内进线客服人数\\n\\n```Plain Text title=\\\"IM中提出退费退款需求的房客数/日均\\\"\\nWITH refund_intent_msgs AS (\\n    -- 1. 过滤：锁定含有退款意图的消息，排除系统卡片“协商退款”\\n    SELECT \\n        from_phx_user_id,\\n        dt,\\n        gmt_create AS intent_time\\n    FROM ba_phx.phx_mdw_detail_message_sync\\n    WHERE dt BETWEEN '20251215' AND '20260115'\\n      AND is_from_phx_host = 0 \\n      AND is_to_phx_host = 1\\n      AND msg_payload RLIKE '(退款|退费|退钱|全额退|申请退|补差价|赔偿|取消订单|取消预订)'\\n      AND msg_payload NOT LIKE '%协商退款%'\\n),\\n\\nrefund_im_users AS (\\n    -- 2. 映射：关联维度表获取 mt_uid，并取用户每天首次意向时间\\n    SELECT \\n        r.from_phx_user_id,\\n        CAST(u.meituan_user_id AS BIGINT) AS mt_uid,\\n        r.dt,\\n        MIN(r.intent_time) AS first_intent_time \\n    FROM refund_intent_msgs r\\n    LEFT JOIN ba_phx.phx_dim_user u ON CAST(r.from_phx_user_id AS STRING) = CAST(u.phx_user_id AS STRING)\\n    GROUP BY 1, 2, 3\\n),\\n\\ncs_cases AS (\\n    -- 3. 客服表：窄化进线数据\\n    SELECT \\n        customer_id AS mt_uid,\\n        case_create_time AS cs_time\\n    FROM ba_phx.phx_topic_csp_case_lifecycle\\n    WHERE case_create_date BETWEEN '2025-12-15' AND '2026-01-16'\\n      AND customer_id IS NOT NULL\\n),\\n\\ndaily_metrics AS (\\n    -- 4. 统计：计算 1 小时内进线的去重人数\\n    SELECT \\n        r.dt,\\n        COUNT(DISTINCT r.from_phx_user_id) AS inquiry_cnt, \\n        COUNT(DISTINCT CASE \\n            WHEN c.cs_time >= r.first_intent_time \\n                 -- 关键修改：21600 (6h) -> 3600 (1h)\\n                 AND (unix_timestamp(c.cs_time) - unix_timestamp(r.first_intent_time)) <= 3600 \\n            THEN r.from_phx_user_id \\n        END) AS escalated_cnt\\n    FROM refund_im_users r\\n    LEFT JOIN cs_cases c ON r.mt_uid = c.mt_uid\\n    GROUP BY r.dt\\n)\\n\\n-- 5. 汇总日均值\\nSELECT \\n    ROUND(AVG(inquiry_cnt), 2) AS avg_daily_refund_inquiry_guests,\\n    ROUND(AVG(escalated_cnt), 2) AS avg_daily_escalated_guests,\\n    ROUND(SUM(escalated_cnt) * 100.0 / SUM(inquiry_cnt), 2) AS period_avg_escalation_rate_pct\\nFROM daily_metrics;\\n```\"\n    },\n    {\n      \"type\": \"table_cell\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          487\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"间隔取1小时\\n\\n取数区间：2025-12-15到2026-01-15\"\n    },\n    {\n      \"type\": \"table_cell\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          281\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"73人/天，占比9.2%\"\n    }\n  ],\n  [\n    {\n      \"type\": \"table_cell\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          513\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"IM内提出**退款退费**需求后，**6小时**内进线客服人数\\n\\n```Plain Text title=\\\"IM内提出退款退费需求后，6小时内进线客服人数/日均\\\"\\nWITH refund_intent_msgs AS (\\n    -- 1. 依然以原始 from_phx_user_id 为准进行过滤\\n    SELECT \\n        from_phx_user_id,\\n        dt,\\n        gmt_create AS intent_time\\n    FROM ba_phx.phx_mdw_detail_message_sync\\n    WHERE dt BETWEEN '20251215' AND '20260115'\\n      AND is_from_phx_host = 0 \\n      AND is_to_phx_host = 1\\n      AND msg_payload RLIKE '(退款|退费|退钱|全额退|申请退|补差价|赔偿|取消订单|取消预订)'\\n      AND msg_payload NOT LIKE '%协商退款%'\\n),\\n\\nrefund_im_users AS (\\n    SELECT \\n        r.from_phx_user_id,\\n        CAST(u.meituan_user_id AS BIGINT) AS mt_uid, -- 用于关联客服的 ID\\n        r.dt,\\n        MIN(r.intent_time) AS first_intent_time \\n    FROM refund_intent_msgs r\\n    LEFT JOIN ba_phx.phx_dim_user u ON CAST(r.from_phx_user_id AS STRING) = CAST(u.phx_user_id AS STRING)\\n    GROUP BY 1, 2, 3\\n),\\n\\ncs_cases AS (\\n    SELECT \\n        customer_id AS mt_uid,\\n        case_create_time AS cs_time\\n    FROM ba_phx.phx_topic_csp_case_lifecycle\\n    WHERE case_create_date BETWEEN '2025-12-15' AND '2026-01-16'\\n      AND customer_id IS NOT NULL\\n),\\n\\ndaily_metrics AS (\\n    SELECT \\n        r.dt,\\n        COUNT(DISTINCT r.from_phx_user_id) AS inquiry_cnt, \\n        COUNT(DISTINCT CASE \\n            WHEN c.cs_time >= r.first_intent_time \\n                 AND unix_timestamp(c.cs_time) - unix_timestamp(r.first_intent_time) <= 21600 \\n            THEN r.from_phx_user_id \\n        END) AS escalated_cnt\\n    FROM refund_im_users r\\n    LEFT JOIN cs_cases c ON r.mt_uid = c.mt_uid\\n    GROUP BY r.dt\\n)\\n\\nSELECT \\n    ROUND(AVG(inquiry_cnt), 2) AS avg_daily_refund_inquiry_guests,\\n    ROUND(AVG(escalated_cnt), 2) AS avg_daily_escalated_guests,\\n    ROUND(SUM(escalated_cnt) * 100.0 / SUM(inquiry_cnt), 2) AS period_avg_escalation_rate_pct\\nFROM daily_metrics;\\n```\"\n    },\n    {\n      \"type\": \"table_cell\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          487\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"间隔取6小时\\n\\n取数区间：2025-12-15到2026-01-15\"\n    },\n    {\n      \"type\": \"table_cell\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          281\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"89人/天，占比11.25%\"\n    }\n  ],\n  [\n    {\n      \"type\": \"table_cell\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          513\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"IM内提出**退款退费**需求后，**24小时**内进线客服人数\\n\\n```Plain Text title=\\\"IM内提出退款退费需求后，6小时内进线客服人数/日均\\\"\\nWITH refund_intent_msgs AS (\\n    -- 1. 过滤：锁定含有退款意图的消息，排除系统卡片“协商退款”\\n    SELECT \\n        from_phx_user_id,\\n        dt,\\n        gmt_create AS intent_time\\n    FROM ba_phx.phx_mdw_detail_message_sync\\n    WHERE dt BETWEEN '20251215' AND '20260115'\\n      AND is_from_phx_host = 0 \\n      AND is_to_phx_host = 1\\n      AND msg_payload RLIKE '(退款|退费|退钱|全额退|申请退|补差价|赔偿|取消订单|取消预订)'\\n      AND msg_payload NOT LIKE '%协商退款%'\\n),\\n\\nrefund_im_users AS (\\n    -- 2. 映射：关联维度表获取 mt_uid，并取用户每天首次意向时间\\n    SELECT \\n        r.from_phx_user_id,\\n        CAST(u.meituan_user_id AS BIGINT) AS mt_uid,\\n        r.dt,\\n        MIN(r.intent_time) AS first_intent_time \\n    FROM refund_intent_msgs r\\n    LEFT JOIN ba_phx.phx_dim_user u ON CAST(r.from_phx_user_id AS STRING) = CAST(u.phx_user_id AS STRING)\\n    GROUP BY 1, 2, 3\\n),\\n\\ncs_cases AS (\\n    -- 3. 客服表：窄化进线数据\\n    SELECT \\n        customer_id AS mt_uid,\\n        case_create_time AS cs_time\\n    FROM ba_phx.phx_topic_csp_case_lifecycle\\n    WHERE case_create_date BETWEEN '2025-12-15' AND '2026-01-16'\\n      AND customer_id IS NOT NULL\\n),\\n\\ndaily_metrics AS (\\n    -- 4. 统计：计算 24 小时内进线的去重人数\\n    SELECT \\n        r.dt,\\n        COUNT(DISTINCT r.from_phx_user_id) AS inquiry_cnt, \\n        COUNT(DISTINCT CASE \\n            WHEN c.cs_time >= r.first_intent_time \\n                 -- 关键修改：3600 (1h) -> 86400 (24h)\\n                 AND (unix_timestamp(c.cs_time) - unix_timestamp(r.first_intent_time)) <= 86400 \\n            THEN r.from_phx_user_id \\n        END) AS escalated_cnt\\n    FROM refund_im_users r\\n    LEFT JOIN cs_cases c ON r.mt_uid = c.mt_uid\\n    GROUP BY r.dt\\n)\\n\\n-- 5. 汇总日均值\\nSELECT \\n    ROUND(AVG(inquiry_cnt), 2) AS avg_daily_refund_inquiry_guests,\\n    ROUND(AVG(escalated_cnt), 2) AS avg_daily_escalated_guests,\\n    ROUND(SUM(escalated_cnt) * 100.0 / SUM(inquiry_cnt), 2) AS period_avg_escalation_rate_pct\\nFROM daily_metrics;\\n```\"\n    },\n    {\n      \"type\": \"table_cell\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          487\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"间隔取24小时\\n\\n取数区间：2025-12-15到2026-01-15\"\n    },\n    {\n      \"type\": \"table_cell\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          281\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"118人/天，占比14.92%\"\n    }\n  ],\n  [\n    {\n      \"type\": \"table_header\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 3,\n        \"colwidth\": [\n          84\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"协商退\"\n    },\n    {\n      \"type\": \"table_cell\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          513\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"IM中提出**协商退需求**的房客数\\n\\n```Plain Text title=\\\"IM中提出协商退需求的房客数/日均\\\"\\nWITH daily_stats AS (\\n    SELECT \\n        dt,\\n        -- 按天对房客ID进行去重，统计每天的提出量\\n        COUNT(DISTINCT from_phx_user_id) AS daily_guest_cnt\\n    FROM ba_phx.phx_mdw_detail_message_sync\\n    WHERE dt BETWEEN '20251215' AND '20260115'\\n      AND is_from_phx_host = 0 \\n      AND is_to_phx_host = 1\\n      AND msg_payload RLIKE '(协商退)'\\n    GROUP BY dt\\n)\\n\\n-- 计算整个时段内的日平均值\\nSELECT \\n    ROUND(AVG(daily_guest_cnt), 2) AS avg_daily_refund_inquiry_guests\\nFROM daily_stats;\\n```\"\n    },\n    {\n      \"type\": \"table_cell\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          487\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"IM中提出协商退相关的房客数，包含协商退卡片的标题\"\n    },\n    {\n      \"type\": \"table_cell\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          281\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"1857人/天\"\n    }\n  ],\n  [\n    {\n      \"type\": \"table_cell\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          513\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"IM中提出**协商退**需求后，**6小时**内进线客服人数\\n\\n```Plain Text title=\\\"IM中提出协商退需求后，6小时内进线客服房客数/日均\\\"\\nWITH \\n-- 1. 瘦身：先从海量 IM 表中过滤出目标消息，减少后续 JOIN 的数据量\\nraw_refund_msgs AS (\\n    SELECT \\n        dt,\\n        from_phx_user_id,\\n        gmt_create AS im_time\\n    FROM ba_phx.phx_mdw_detail_message_sync\\n    WHERE dt BETWEEN '20251215' AND '20260115'\\n      AND is_from_phx_host = 0 \\n      AND is_to_phx_host = 1\\n      -- 优化点：RLIKE 是计算密集型，先通过 dt 和方向过滤掉 90% 的数据再匹配关键词\\n      AND msg_payload RLIKE '(协商退)'\\n),\\n\\n-- 2. 映射：仅针对过滤后的用户进行 ID 转换\\nrefund_im_daily AS (\\n    SELECT \\n        r.dt,\\n        CAST(u.meituan_user_id AS BIGINT) AS mt_uid, \\n        r.im_time\\n    FROM raw_refund_msgs r\\n    JOIN ba_phx.phx_dim_user u \\n        ON CAST(r.from_phx_user_id AS STRING) = CAST(u.phx_user_id AS STRING)\\n),\\n\\n-- 3. 窄化：仅拉取对应区间内的客服 ID，减少内存占用\\ncs_cases AS (\\n    SELECT \\n        customer_id AS mt_uid,\\n        case_create_time AS cs_time\\n    FROM ba_phx.phx_topic_csp_case_lifecycle\\n    WHERE case_create_date BETWEEN '2025-12-15' AND '2026-01-16'\\n      AND customer_id IS NOT NULL\\n),\\n\\n-- 4. 聚合：按天统计\\ndaily_metrics AS (\\n    SELECT \\n        r.dt,\\n        COUNT(DISTINCT r.mt_uid) AS inquiry_cnt,\\n        COUNT(DISTINCT CASE \\n            WHEN c.cs_time >= r.im_time \\n                 AND (unix_timestamp(c.cs_time) - unix_timestamp(r.im_time)) <= 21600 \\n            THEN r.mt_uid \\n        END) AS escalated_cnt\\n    FROM refund_im_daily r\\n    LEFT JOIN cs_cases c ON r.mt_uid = c.mt_uid\\n    GROUP BY r.dt\\n)\\n\\n-- 5. 汇总：计算日均\\nSELECT \\n    ROUND(AVG(inquiry_cnt), 2) AS avg_daily_refund_inquiry_guests,\\n    ROUND(AVG(escalated_cnt), 2) AS avg_daily_escalated_guests,\\n    ROUND(SUM(escalated_cnt) * 100.0 / SUM(inquiry_cnt), 2) AS period_avg_escalation_rate_pct\\nFROM daily_metrics;\\n```\"\n    },\n    {\n      \"type\": \"table_cell\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          487\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"间隔取6小时\\n\\n取数区间：2025-12-15到2026-01-15\"\n    },\n    {\n      \"type\": \"table_cell\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          281\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"195.06人/天，占比10.5%\"\n    }\n  ],\n  [\n    {\n      \"type\": \"table_cell\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          513\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"IM中提出**协商退**需求后，**24小时**内进线客服人数\\n\\n```Plain Text title=\\\"IM中提出协商退需求后，24小时内进线客服房客数/日均\\\"\\nWITH \\n-- 1. 基础池：圈选目标日期内有退款意图的房客\\nraw_refund_msgs AS (\\n    SELECT \\n        dt,\\n        from_phx_user_id,\\n        gmt_create AS im_time\\n    FROM ba_phx.phx_mdw_detail_message_sync\\n    WHERE dt BETWEEN '20251215' AND '20260115'\\n      AND is_from_phx_host = 0 \\n      AND is_to_phx_host = 1\\n      AND msg_payload LIKE '%协商退%'\\n),\\n\\n-- 2. 映射：桥接美团 ID\\nrefund_im_daily AS (\\n    SELECT \\n        r.dt,\\n        CAST(u.meituan_user_id AS BIGINT) AS mt_uid, \\n        r.im_time\\n    FROM raw_refund_msgs r\\n    JOIN ba_phx.phx_dim_user u \\n        ON CAST(r.from_phx_user_id AS STRING) = CAST(u.phx_user_id AS STRING)\\n),\\n\\n-- 3. 匹配池：客服工单需多覆盖一天（至 01-16），确保 01-15 晚上的用户有 24h 观测窗口\\ncs_cases AS (\\n    SELECT \\n        customer_id AS mt_uid,\\n        case_create_time AS cs_time\\n    FROM ba_phx.phx_topic_csp_case_lifecycle\\n    WHERE case_create_date BETWEEN '2025-12-15' AND '2026-01-16'\\n      AND customer_id IS NOT NULL\\n),\\n\\n-- 4. 核心逻辑：判定 24 小时（86400 秒）内的进线情况\\ndaily_metrics AS (\\n    SELECT \\n        r.dt,\\n        COUNT(DISTINCT r.mt_uid) AS inquiry_cnt,\\n        COUNT(DISTINCT CASE \\n            WHEN c.cs_time >= r.im_time \\n                 AND (unix_timestamp(c.cs_time) - unix_timestamp(r.im_time)) <= 86400 \\n            THEN r.mt_uid \\n        END) AS escalated_24h_cnt\\n    FROM refund_im_daily r\\n    LEFT JOIN cs_cases c ON r.mt_uid = c.mt_uid\\n    GROUP BY r.dt\\n)\\n\\n-- 5. 汇总：计算全月日均值\\nSELECT \\n    ROUND(AVG(inquiry_cnt), 2) AS avg_daily_refund_inquiry_guests,\\n    ROUND(AVG(escalated_24h_cnt), 2) AS avg_daily_escalated_24h_guests,\\n    ROUND(SUM(escalated_24h_cnt) * 100.0 / SUM(inquiry_cnt), 2) AS period_avg_escalation_rate_24h_pct\\nFROM daily_metrics;\\n```\"\n    },\n    {\n      \"type\": \"table_cell\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          487\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"间隔取24小时\\n\\n取数区间：2025-12-15到2026-01-15\"\n    },\n    {\n      \"type\": \"table_cell\",\n      \"attrs\": {\n        \"colspan\": 1,\n        \"rowspan\": 1,\n        \"colwidth\": [\n          281\n        ],\n        \"textAlign\": null,\n        \"verticalAlign\": null,\n        \"bgColor\": null,\n        \"color\": null,\n        \"numCell\": null\n      },\n      \"content\": \"242.41人/天，占比13.05%\"\n    }\n  ]\n]\n:::\n:::\n:::"
    }
  ],
