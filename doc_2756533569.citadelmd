``` nodeId="0514989a-518c-4286-8847-a16b7def9b9e"
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IM退款自助化-有损引导场景</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #f0f2f5; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
        .phone-mockup { width: 375px; height: 720px; background: #ededed; display: flex; flex-direction: column; overflow: hidden; border: 8px solid #333; border-radius: 32px; box-shadow: 0 20px 50px rgba(0,0,0,0.15); }
        .chat-area { flex: 1; padding: 12px; overflow-y: auto; scrollbar-width: none; }
        .chat-area::-webkit-scrollbar { display: none; }
        .card-shadow { box-shadow: 0 2px 12px rgba(0,0,0,0.08); }
        .btn-active:active { opacity: 0.8; transform: scale(0.96); }
    </style>
</head>
<body class="p-8 text-left">

    <div class="max-w-6xl mx-auto flex flex-wrap justify-center gap-12 text-left">
        
        <!-- ================= 房客端 (Guest) - 有损场景 ================= -->
        <div class="flex flex-col items-center">
            <h2 class="mb-4 text-lg font-bold text-gray-700 flex items-center text-center leading-tight">
                <span class="w-3 h-3 bg-blue-500 rounded-full mr-2"></span> 房客端视角
            </h2>
            <div class="phone-mockup relative text-left">
                <!-- 顶部栏 -->
                <div class="bg-[#f7f7f7] p-4 flex items-center border-b border-gray-200">
                    <div class="w-7 h-7 bg-blue-500 rounded-full mr-2 flex items-center justify-center text-[10px] text-white font-bold">房东</div>
                    <div class="font-bold text-gray-800 text-xs text-left">美团民宿房东</div>
                </div>

                <div class="chat-area text-left">
                    <!-- 1. 房客咨询 -->
                    <div class="flex justify-end mb-4 text-left">
                        <div class="bg-[#ffda00] text-gray-800 p-2.5 rounded-2xl rounded-tr-none max-w-[75%] text-[13px] text-left">临时去不了了，能退多少钱？</div>
                        <div class="w-7 h-7 bg-orange-400 rounded-full ml-2 flex items-center justify-center text-[10px] text-white font-bold flex-shrink-0">客</div>
                    </div>

                    <!-- 2. 退改政策卡片 (增加挽留提示) -->
                    <div class="flex justify-start mb-3 text-left">
                        <div class="w-7 h-7 bg-white border border-gray-200 rounded-full mr-2 flex items-center justify-center text-[10px] text-orange-500 font-bold flex-shrink-0">美</div>
                        <div class="bg-white rounded-2xl w-[300px] card-shadow border border-gray-100 overflow-hidden text-left text-left">
                            <div class="p-3 flex bg-gray-50/50 border-b border-gray-50 text-left text-left">
                                <div class="w-14 h-14 bg-gray-200 rounded-lg flex-shrink-0 overflow-hidden text-left">
                                    <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=200&h=200&fit=crop" class="w-full h-full object-cover">
                                </div>
                                <div class="ml-3 flex-1 flex flex-col justify-center text-left text-left">
                                    <div class="font-bold text-[13px] text-gray-800 truncate mb-1 text-left">釜子锅的测试房</div>
                                    <div class="text-[11px] text-gray-500 text-left">10.10－10.15 | 合计 ¥139</div>
                                </div>
                            </div>
                            
                            <div class="p-4 text-left text-left">
                                <div class="text-left mb-3 text-left">
                                    <div class="flex justify-between items-baseline text-left">
                                        <div class="text-orange-500 font-bold text-[14px]">有损取消</div>
                                        <div class="text-red-500 font-bold text-[15px]">预计退 ¥97.30</div>
                                    </div>
                                    <p class="text-[10px] text-gray-400 mt-1 text-left">当前取消需扣除30%违约金 <span class="text-blue-500 cursor-pointer">详情 ></span></p>
                                </div>

                                <!-- 房客端温馨提示：挽留话术 -->
                                <div class="bg-amber-50 rounded-lg p-2.5 mb-4 border border-amber-100 text-left text-left">
                                    <div class="flex items-start text-left">
                                        <span class="text-amber-500 mr-1.5 mt-0.5">💡</span>
                                        <p class="text-[11px] text-amber-700 leading-normal font-medium text-left">温馨提示：房间已为您预留，建议您按计划入住，不负旅途好时光，留住绝美行程体验。</p>
                                    </div>
                                </div>

                                <div class="flex gap-2 text-left">
                                    <button class="flex-1 bg-white border border-gray-200 text-gray-500 py-2.5 rounded-lg text-[13px] font-medium btn-active text-center">付费取消</button>
                                    <button class="flex-1 bg-[#ffda00] py-2.5 rounded-lg text-[13px] font-bold btn-active text-center shadow-sm">继续入住</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 3. 平台协商退小助手 -->
                    <div class="flex justify-start mb-4 text-left">
                        <div class="w-7 h-7 bg-transparent mr-2 flex-shrink-0"></div>
                        <div class="bg-white rounded-2xl w-[300px] p-4 card-shadow border border-blue-50 text-left text-left">
                            <div class="flex items-center mb-1.5 text-blue-600 text-left">
                                <div class="bg-blue-500 rounded p-0.5 mr-1.5 flex items-center justify-center text-left">
                                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"></path></svg>
                                </div>
                                <span class="text-[12px] font-bold text-left">平台协商退小助手</span>
                            </div>
                            <p class="text-[11px] text-gray-500 mb-3 leading-relaxed text-left">
                                违约金太高？您可以向房东友好协商。说明您的<span class="text-blue-600 font-bold">特殊困难</span>，争取减少损失。
                            </p>
                            <div class="flex gap-2 text-left">
                                <button class="flex-1 border border-blue-100 bg-blue-50 text-blue-600 py-1.5 rounded-lg text-[11px] font-bold btn-active text-center text-center">电话联系</button>
                                <button class="flex-1 bg-blue-500 text-white py-1.5 rounded-lg text-[11px] font-bold btn-active shadow-md shadow-blue-50 text-center text-center">发送协商意向</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 底部输入栏 -->
                <div class="bg-white p-3 pb-8 border-t border-gray-200 text-left text-left">
                    <div class="bg-gray-100 h-9 rounded-full px-4 flex items-center text-gray-400 text-sm text-left">请输入...</div>
                </div>
            </div>
        </div>

        <!-- ================= 房东端 (Host) - 仅状态同步 ================= -->
        <div class="flex flex-col items-center text-left">
            <h2 class="mb-4 text-lg font-bold text-gray-700 flex items-center text-center leading-tight">
                <span class="w-3 h-3 bg-orange-500 rounded-full mr-2"></span> 房东端视角
            </h2>
            <div class="phone-mockup relative text-left">
                <div class="bg-[#f7f7f7] p-4 flex items-center border-b border-gray-200">
                    <div class="w-7 h-7 bg-orange-400 rounded-full mr-2 flex items-center justify-center text-[10px] text-white font-bold">客</div>
                    <div class="font-bold text-gray-800 text-xs text-left">美团民宿房客</div>
                </div>

                <div class="chat-area flex flex-col text-left">
                    <div class="flex justify-start mb-4 text-left">
                        <div class="w-7 h-7 bg-orange-400 rounded-full mr-2 flex items-center justify-center text-[10px] text-white font-bold flex-shrink-0">客</div>
                        <div class="bg-white text-gray-800 p-2.5 rounded-2xl rounded-tl-none text-[13px] shadow-sm italic text-left">临时去不了了，能退多少钱？</div>
                    </div>
                    
                    <!-- 房东侧看到的政策卡片同步 (移除按钮，做截断) -->
                    <div class="flex justify-end mb-4 text-left text-left">
                        <div class="bg-white rounded-2xl w-[300px] overflow-hidden card-shadow border border-gray-100 mr-2 text-left">
                            <div class="p-3 flex bg-gray-50/50 border-b border-gray-50 text-left text-left text-left">
                                <div class="w-14 h-14 bg-gray-200 rounded-lg flex-shrink-0 overflow-hidden text-left">
                                    <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=200&h=200&fit=crop" class="w-full h-full object-cover">
                                </div>
                                <div class="ml-3 flex-1 flex flex-col justify-center text-left text-left">
                                    <div class="font-bold text-[13px] text-gray-800 truncate mb-1">釜子锅的测试房</div>
                                    <div class="text-[11px] text-gray-500">¥139.00</div>
                                </div>
                            </div>
                            <div class="p-3 text-left text-left text-left text-left">
                                <div class="flex justify-between items-center text-left text-left">
                                    <div class="text-left text-left text-left text-left text-left text-left">
                                        <div class="text-orange-500 font-bold text-[13px]">有损取消</div>
                                        <p class="text-[9px] text-gray-400 mt-0.5 text-left text-left">房客当前取消需扣30%</p>
                                    </div>
                                    <div class="text-right text-right text-right">
                                        <div class="text-[10px] text-gray-400 text-right">预计退还金额</div>
                                        <div class="text-red-500 font-bold text-[15px]">¥97.30</div>
                                    </div>
                                </div>

                                <!-- 房东端温馨提示：帮房东挽留 -->
                                <div class="mt-3 bg-amber-50 rounded-lg p-2.5 border border-amber-100 text-left text-left">
                                    <div class="flex items-start text-left text-left">
                                        <span class="text-amber-500 mr-1.5 mt-0.5 text-left">💡</span>
                                        <p class="text-[11px] text-amber-700 leading-normal font-medium text-left">温馨提示：房间已为您预留，建议您按计划入住，不负旅途好时光，留住绝美行程体验。</p>
                                    </div>
                                </div>
                            </div>
                            <!-- 此处已移除按钮展示，实现视觉截断 -->
                        </div>
                        <div class="w-7 h-7 bg-white border border-gray-200 rounded-full flex items-center justify-center text-[10px] text-orange-500 font-bold flex-shrink-0 self-start text-center">美</div>
                    </div>

                    <div class="mt-2 px-8 text-center text-center text-center">
                        <p class="text-[10px] text-gray-400 italic">房东端已同步展示最新退改规则</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
```
