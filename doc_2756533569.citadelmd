``` nodeId="8f5edab3-49c2-4b32-bdb8-373f8983f8ac"
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IM退款自助化-追加确认卡片</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #f0f2f5; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
        .phone-mockup { width: 375px; height: 720px; background: #ededed; display: flex; flex-direction: column; overflow: hidden; border: 8px solid #333; border-radius: 32px; box-shadow: 0 20px 50px rgba(0,0,0,0.15); position: relative; }
        .chat-area { flex: 1; padding: 12px; overflow-y: auto; scrollbar-width: none; scroll-behavior: smooth; }
        .chat-area::-webkit-scrollbar { display: none; }
        .card-shadow { box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
        .btn-active:active { opacity: 0.8; transform: scale(0.96); }
        
        /* 动画进入效果 */
        @keyframes slideIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-slide { animation: slideIn 0.3s ease-out forwards; }
    </style>
</head>
<body class="p-8">

    <div class="max-w-6xl mx-auto flex flex-wrap justify-center gap-12">
        
        <!-- ================= 房客端 (Guest) ================= -->
        <div class="flex flex-col items-center">
            <h2 class="mb-4 text-lg font-bold text-gray-700 flex items-center">
                <span class="w-3 h-3 bg-blue-500 rounded-full mr-2"></span> 房客端视角
            </h2>
            <div class="phone-mockup">
                <!-- 顶部栏 -->
                <div class="bg-[#f7f7f7] p-4 flex items-center border-b border-gray-200 sticky top-0 z-10">
                    <div class="w-7 h-7 bg-blue-500 rounded-full mr-2 flex items-center justify-center text-[10px] text-white font-bold">房东</div>
                    <div class="font-bold text-gray-800 text-xs">美团民宿房东</div>
                </div>

                <div class="chat-area" id="guestChat">
                    <!-- 1. 房客咨询 -->
                    <div class="flex justify-end mb-5">
                        <div class="bg-[#ffda00] text-gray-800 p-3 rounded-2xl rounded-tr-none max-w-[75%] text-[13px]">临时去不了了，能退多少钱？</div>
                        <div class="w-7 h-7 bg-orange-400 rounded-full ml-2 flex items-center justify-center text-[10px] text-white font-bold flex-shrink-0">客</div>
                    </div>

                    <!-- 2. 初始引导卡片 (卡片 A) -->
                    <div class="flex justify-start mb-5" id="cardAContainer">
                        <div class="w-7 h-7 bg-white border border-gray-200 rounded-full mr-2 flex items-center justify-center text-[10px] text-orange-500 font-bold flex-shrink-0">美</div>
                        <div class="bg-white rounded-2xl w-[290px] card-shadow border border-gray-100 overflow-hidden">
                            <div class="p-3 bg-gray-50 flex items-center border-b border-gray-100">
                                <span class="text-[11px] font-bold text-gray-600">退改政策试算</span>
                            </div>
                            <div class="p-4">
                                <div class="flex justify-between items-center mb-3">
                                    <span class="text-[13px] text-gray-800">预计退还金额</span>
                                    <span class="text-red-500 font-bold text-[16px]">¥97.30</span>
                                </div>
                                <div class="bg-amber-50 rounded-lg p-2.5 mb-4 border border-amber-100">
                                    <p class="text-[11px] text-amber-700 leading-relaxed">💡 房间已为您预留，现在取消将扣除 ¥41.70 违约金。建议您按原计划入住。</p>
                                </div>
                                <div class="flex gap-2">
                                    <button onclick="sendConfirmCard(this)" class="flex-1 bg-white border border-gray-200 text-gray-500 py-2.5 rounded-lg text-[12px] font-medium btn-active">坚持取消</button>
                                    <button class="flex-1 bg-[#ffda00] py-2.5 rounded-lg text-[12px] font-bold btn-active">继续入住</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 动态追加区 -->
                    <div id="dynamicContentGuest"></div>
                </div>

                <!-- 底部输入栏 -->
                <div class="bg-white p-3 pb-8 border-t border-gray-200">
                    <div class="bg-gray-100 h-9 rounded-full px-4 flex items-center text-gray-400 text-[12px]">请输入您的回复...</div>
                </div>
            </div>
        </div>

        <!-- ================= 房东端 (Host) ================= -->
        <div class="flex flex-col items-center">
            <h2 class="mb-4 text-lg font-bold text-gray-700 flex items-center">
                <span class="w-3 h-3 bg-orange-500 rounded-full mr-2"></span> 房东端视角
            </h2>
            <div class="phone-mockup">
                <div class="bg-[#f7f7f7] p-4 flex items-center border-b border-gray-200 sticky top-0 z-10">
                    <div class="w-7 h-7 bg-orange-400 rounded-full mr-2 flex items-center justify-center text-[10px] text-white font-bold">客</div>
                    <div class="font-bold text-gray-800 text-xs">美团民宿房客</div>
                </div>

                <div class="chat-area" id="hostChat">
                    <div class="flex justify-start mb-5">
                        <div class="w-7 h-7 bg-orange-400 rounded-full mr-2 flex items-center justify-center text-[10px] text-white font-bold flex-shrink-0">客</div>
                        <div class="bg-white text-gray-800 p-3 rounded-2xl rounded-tl-none text-[13px] shadow-sm">临时去不了了，能退多少钱？</div>
                    </div>
                    
                    <div class="flex justify-end mb-5">
                        <div class="bg-white rounded-2xl w-[290px] overflow-hidden card-shadow border border-gray-100 mr-2">
                            <div class="p-3 border-b border-gray-100 flex justify-between items-center bg-gray-50">
                                <span class="text-[11px] text-gray-500">向房客展示的退改政策</span>
                            </div>
                            <div class="p-4">
                                <div class="flex justify-between items-center">
                                    <span class="text-[12px] text-gray-600">有损取消金额</span>
                                    <span class="text-red-500 font-bold text-[14px]">¥97.30</span>
                                </div>
                            </div>
                        </div>
                        <div class="w-7 h-7 bg-white border border-gray-200 rounded-full flex items-center justify-center text-[10px] text-orange-500 font-bold flex-shrink-0">美</div>
                    </div>

                    <!-- 动态追加区 -->
                    <div id="dynamicContentHost"></div>
                </div>
                
                <div class="bg-white p-3 pb-8 border-t border-gray-200">
                    <div class="bg-gray-100 h-9 rounded-full px-4 flex items-center text-gray-400 text-[12px]">请输入...</div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function sendConfirmCard(btn) {
            // 1. 禁用原卡片按钮避免重复点击
            btn.disabled = true;
            btn.classList.add('opacity-50');
            
            const guestContainer = document.getElementById('dynamicContentGuest');
            const hostContainer = document.getElementById('dynamicContentHost');

            // 2. 模拟房客发送“坚持取消”文本消息
            const textMsg = `
                <div class="flex justify-end mb-5 animate-slide">
                    <div class="bg-[#ffda00] text-gray-800 p-2.5 rounded-2xl rounded-tr-none text-[13px]">坚持取消</div>
                    <div class="w-7 h-7 bg-orange-400 rounded-full ml-2 flex items-center justify-center text-[10px] text-white font-bold flex-shrink-0">客</div>
                </div>
            `;
            guestContainer.innerHTML += textMsg;

            // 3. 延迟下发新卡片 (卡片 B)
            setTimeout(() => {
                const confirmCard = `
                    <div class="flex justify-start mb-5 animate-slide">
                        <div class="w-7 h-7 bg-white border border-gray-200 rounded-full mr-2 flex items-center justify-center text-[10px] text-orange-500 font-bold flex-shrink-0 self-start">美</div>
                        <div class="bg-white rounded-2xl w-[290px] card-shadow border border-blue-100 overflow-hidden">
                            <div class="p-4 bg-white">
                                <div class="text-center mb-4">
                                    <div class="text-[14px] font-bold text-gray-800 mb-1">确认取消订单并支付违约金？</div>
                                    <p class="text-[11px] text-gray-400">取消后，¥97.30 将原路退回支付账号</p>
                                </div>
                                <div class="space-y-3">
                                    <button class="w-full bg-[#ffda00] py-3 rounded-xl text-[14px] font-bold btn-active shadow-sm">付费取消</button>
                                    
                                    <div class="flex flex-col items-center pt-1">
                                        <div class="flex items-center w-full px-4 mb-2">
                                            <div class="h-[1px] bg-gray-100 flex-1"></div>
                                            <span class="px-2 text-[10px] text-gray-300">或</span>
                                            <div class="h-[1px] bg-gray-100 flex-1"></div>
                                        </div>
                                        <button onclick="showFinalNego()" class="text-blue-500 text-[12px] font-medium py-1 px-4">与房东协商退更多 ></button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
                guestContainer.innerHTML += confirmCard;
                
                // 同步给房东端
                hostContainer.innerHTML += `
                    <div class="flex justify-start mb-4 animate-slide">
                        <div class="w-7 h-7 bg-orange-400 rounded-full mr-2 flex items-center justify-center text-[10px] text-white font-bold flex-shrink-0">客</div>
                        <div class="bg-white text-gray-800 p-2.5 rounded-2xl rounded-tl-none text-[13px] shadow-sm">坚持取消</div>
                    </div>
                    <div class="flex justify-end mb-5 animate-slide">
                        <div class="bg-white rounded-2xl w-[290px] overflow-hidden card-shadow border border-gray-100 mr-2">
                             <div class="p-4 text-center">
                                <div class="text-[12px] font-bold text-gray-700">房客正在决策“付费取消”</div>
                                <p class="text-[10px] text-gray-400 mt-1">系统已下发二次确认卡片</p>
                             </div>
                        </div>
                        <div class="w-7 h-7 bg-white border border-gray-200 rounded-full flex items-center justify-center text-[10px] text-orange-500 font-bold flex-shrink-0">美</div>
                    </div>
                `;

                // 滚动
                scrollToBottom();
            }, 600);
        }

        function showFinalNego() {
             const guestContainer = document.getElementById('dynamicContentGuest');
             const negoCard = `
                <div class="flex justify-start mb-5 animate-slide">
                    <div class="w-7 h-7 bg-transparent mr-2 flex-shrink-0"></div>
                    <div class="bg-blue-50 rounded-2xl w-[290px] p-4 border border-blue-100">
                        <div class="flex items-center mb-2">
                            <span class="text-blue-600 font-bold text-[12px]">协商退款助手</span>
                        </div>
                        <p class="text-[11px] text-blue-800/70 leading-relaxed mb-3">若您有特殊困难（如就医、交通取消等），可尝试提供证明与房东友好协商。</p>
                        <button class="w-full bg-white border border-blue-200 text-blue-600 py-2 rounded-lg text-[11px] font-bold btn-active">向房东反馈困难</button>
                    </div>
                </div>
             `;
             guestContainer.innerHTML += negoCard;
             scrollToBottom();
        }

        function scrollToBottom() {
            const guestChat = document.getElementById('guestChat');
            const hostChat = document.getElementById('hostChat');
            guestChat.scrollTop = guestChat.scrollHeight;
            hostChat.scrollTop = hostChat.scrollHeight;
        }
    </script>
</body>
</html>
```

