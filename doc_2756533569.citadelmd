``` nodeId="9fe03f40-415e-4892-8cb5-98b55183bc52"
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IM退款自助化-受限引导场景</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #f0f2f5; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
        .phone-mockup { width: 375px; height: 720px; background: #ededed; display: flex; flex-direction: column; overflow: hidden; border: 8px solid #333; border-radius: 32px; box-shadow: 0 20px 50px rgba(0,0,0,0.15); }
        .chat-area { flex: 1; padding: 12px; overflow-y: auto; scrollbar-width: none; }
        .chat-area::-webkit-scrollbar { display: none; }
        .card-shadow { box-shadow: 0 2px 12px rgba(0,0,0,0.08); }
        .btn-active:active { opacity: 0.8; transform: scale(0.96); }
    </style>
</head>
<body class="p-8 text-left">

    <div class="max-w-6xl mx-auto flex flex-wrap justify-center gap-12 text-left">
        
        <!-- ================= 房客端 (Guest) - 受限场景 ================= -->
        <div class="flex flex-col items-center">
            <h2 class="mb-4 text-lg font-bold text-gray-700 flex items-center text-center leading-tight">
                <span class="w-3 h-3 bg-blue-500 rounded-full mr-2"></span> 房客端视角 (引导协商)
            </h2>
            <div class="phone-mockup relative text-left">
                <!-- 顶部栏 -->
                <div class="bg-[#f7f7f7] p-4 flex items-center border-b border-gray-200">
                    <div class="w-7 h-7 bg-blue-500 rounded-full mr-2 flex items-center justify-center text-[10px] text-white font-bold">房东</div>
                    <div class="font-bold text-gray-800 text-xs">美团民宿房东</div>
                </div>

                <div class="chat-area text-left">
                    <!-- 1. 房客咨询 + 头像 -->
                    <div class="flex justify-end mb-4">
                        <div class="bg-[#ffda00] text-gray-800 p-2.5 rounded-2xl rounded-tr-none max-w-[75%] text-[13px]">临时去不了了，能退吗？</div>
                        <div class="w-7 h-7 bg-orange-400 rounded-full ml-2 flex items-center justify-center text-[10px] text-white font-bold flex-shrink-0">客</div>
                    </div>

                    <!-- 2. 退改政策卡片 -->
                    <div class="flex justify-start mb-3 text-left">
                        <div class="w-7 h-7 bg-white border border-gray-200 rounded-full mr-2 flex items-center justify-center text-[10px] text-orange-500 font-bold flex-shrink-0 text-left">美</div>
                        <div class="bg-white rounded-2xl w-[300px] card-shadow border border-gray-100 overflow-hidden text-left">
                            <div class="p-3 flex bg-gray-50/50 border-b border-gray-50 text-left">
                                <div class="w-16 h-16 bg-gray-200 rounded-lg flex-shrink-0 overflow-hidden">
                                    <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=200&h=200&fit=crop" class="w-full h-full object-cover">
                                </div>
                                <div class="ml-3 flex-1 flex flex-col justify-center text-left">
                                    <div class="font-bold text-[13px] text-gray-800 truncate mb-1">釜子锅的测试房</div>
                                    <div class="text-[11px] text-gray-500">10.10－10.15 | 合计 ¥139</div>
                                </div>
                            </div>
                            <div class="p-3 text-left">
                                <div class="text-left mb-2">
                                    <div class="text-red-500 font-bold text-[14px]">不可取消</div>
                                    <p class="text-[10px] text-gray-400 mt-0.5">取消将扣除全额房费 <span class="text-blue-500">详情 ></span></p>
                                </div>
                                <!-- 温馨提示 -->
                                <div class="mt-2 bg-blue-50/50 p-2.5 rounded-lg border border-blue-100/30 italic text-blue-800 text-[10px] leading-relaxed text-left">
                                    💡 温馨提示：房间已为您预留，建议您按原计划入住，不负旅途好时光，留住这段美好旅程。
                                </div>
                                <div class="mt-4 flex gap-2">
                                    <button class="flex-1 bg-[#ffda00] py-2.5 rounded-lg text-[12px] font-bold btn-active">修改日期</button>
                                    <button class="flex-1 bg-white border border-gray-200 text-gray-400 py-2 rounded-lg text-[11px] cursor-not-allowed">坚持取消</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 3. 引导卡片 (已修正标题) -->
                    <div class="flex justify-start mb-4 text-left">
                        <div class="w-7 h-7 bg-transparent mr-2 flex-shrink-0"></div> <!-- 对齐占位 -->
                        <div class="bg-white rounded-2xl w-[300px] p-4 card-shadow border border-blue-50 text-left">
                            <div class="flex items-center mb-1.5 text-blue-600 text-left">
                                <div class="bg-blue-500 rounded p-0.5 mr-1.5 flex items-center justify-center">
                                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"></path></svg>
                                </div>
                                <span class="text-[12px] font-bold">平台协商退小助手</span>
                            </div>
                            <p class="text-[11px] text-gray-500 mb-3 leading-relaxed text-left">
                                若上述方案无法解决，您可以向房东友好协商。建议先<span class="text-blue-600 font-bold">说明真实困难</span>，房东更易理解。
                            </p>
                            <div class="flex gap-2">
                                <button class="flex-1 border border-blue-100 bg-blue-50 text-blue-600 py-1.5 rounded-lg text-[11px] font-bold btn-active">电话联系</button>
                                <button class="flex-1 bg-blue-500 text-white py-1.5 rounded-lg text-[11px] font-bold btn-active shadow-md shadow-blue-50">发送协商意向</button>
                            </div>
                        </div>
                    </div>

                    <!-- 4. 固定话术 -->
                    <div class="flex justify-end mb-4">
                        <div class="bg-[#ffda00] text-gray-800 p-3 rounded-2xl rounded-tr-none max-w-[80%] text-[13px] leading-snug card-shadow text-left">
                            房东您好，我有特殊情况希望能协商退款，如您同意，请您发送<span class="font-bold underline">协商退款链接</span>给我，谢谢。
                        </div>
                        <div class="w-7 h-7 bg-orange-400 rounded-full ml-2 flex items-center justify-center text-[10px] text-white font-bold flex-shrink-0">客</div>
                    </div>
                </div>

                <!-- 底部输入栏 -->
                <div class="bg-white p-3 pb-8 border-t border-gray-200">
                    <div class="bg-gray-100 h-9 rounded-full px-4 flex items-center text-gray-400 text-sm">请输入...</div>
                </div>
            </div>
        </div>

        <!-- ================= 房东端 (Host) - 信息对称 ================= -->
        <div class="flex flex-col items-center">
            <h2 class="mb-4 text-lg font-bold text-gray-700 flex items-center text-center leading-tight">
                <span class="w-3 h-3 bg-orange-500 rounded-full mr-2"></span> 房东端视角 (信息对齐)
            </h2>
            <div class="phone-mockup relative">
                <div class="bg-[#f7f7f7] p-4 flex items-center border-b border-gray-200">
                    <div class="w-7 h-7 bg-orange-400 rounded-full mr-2 flex items-center justify-center text-[10px] text-white font-bold">客</div>
                    <div class="font-bold text-gray-800 text-xs">美团民宿房客</div>
                </div>

                <div class="chat-area flex flex-col text-left">
                    <div class="flex justify-start mb-4">
                        <div class="w-7 h-7 bg-orange-400 rounded-full mr-2 flex items-center justify-center text-[10px] text-white font-bold flex-shrink-0">客</div>
                        <div class="bg-white text-gray-800 p-2.5 rounded-2xl rounded-tl-none text-[13px] shadow-sm italic text-left">临时去不了了，能退吗？</div>
                    </div>
                    <div class="flex justify-end mb-4 text-left">
                        <div class="bg-white rounded-2xl w-[300px] overflow-hidden card-shadow border border-gray-100 mr-2 text-left">
                            <div class="p-3 flex bg-gray-50/50 border-b border-gray-50 text-left">
                                <div class="w-16 h-16 bg-gray-200 rounded-lg flex-shrink-0 overflow-hidden">
                                    <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=200&h=200&fit=crop" class="w-full h-full object-cover">
                                </div>
                                <div class="ml-3 flex-1 text-left flex flex-col justify-center">
                                    <div class="font-bold text-[13px] text-gray-800 truncate mb-1 text-left">釜子锅的测试房</div>
                                    <div class="text-[11px] text-gray-500 text-left">10.10－10.15 | 合计 ¥139</div>
                                </div>
                            </div>
                            <div class="p-3 text-left">
                                <div class="flex justify-between items-start mb-2 text-left">
                                    <div class="text-left">
                                        <div class="text-red-500 font-bold text-[13px]">不可取消</div>
                                        <p class="text-[9px] text-gray-400 mt-0.5">系统已同步扣费政策</p>
                                    </div>
                                    <div class="text-right">
                                        <div class="text-red-500 font-bold text-[13px]">¥139.00</div>
                                    </div>
                                </div>
                                <div class="mt-2 bg-blue-50/30 p-2 rounded-lg border border-blue-100/20 italic text-blue-800 text-[9px] leading-relaxed text-left">
                                    💡 温馨提示：房间已为您预留，建议您按原计划入住，不负旅途好时光，留住这段美好旅程。
                                </div>
                            </div>
                        </div>
                        <div class="w-7 h-7 bg-white border border-gray-200 rounded-full flex items-center justify-center text-[10px] text-orange-500 font-bold flex-shrink-0 self-start text-left">美</div>
                    </div>
                    <div class="flex justify-start mb-4 text-left">
                        <div class="w-7 h-7 bg-orange-400 rounded-full mr-2 flex items-center justify-center text-[10px] text-white font-bold flex-shrink-0">客</div>
                        <div class="bg-white text-gray-800 p-3 rounded-2xl rounded-tl-none max-w-[80%] text-[13px] leading-snug shadow-sm text-left">
                            房东您好，我有特殊情况希望能协商退款，如您同意，请您发送<span class="font-bold underline">协商退款链接</span>给我，谢谢。
                        </div>
                    </div>
                    <div class="flex justify-end mb-4 text-left">
                        <div class="bg-white rounded-xl p-3 border border-blue-100 w-[260px] mr-2 text-left shadow-sm">
                            <p class="text-[11px] text-gray-800 mb-2 font-bold text-left">房客寻求协商</p>
                            <p class="text-[10px] text-gray-500 mb-3 text-left">您可以点击下方按钮，向房客下发协商退款单：</p>
                            <button class="w-full bg-blue-500 text-white py-2 rounded-lg text-[12px] font-bold shadow-md shadow-blue-50 active:opacity-90">
                                发送“协商退款单”
                            </button>
                        </div>
                        <div class="w-7 h-7 bg-white border border-gray-200 rounded-full flex items-center justify-center text-[10px] text-orange-500 font-bold flex-shrink-0 self-start">美</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
```

