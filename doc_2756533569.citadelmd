``` nodeId="08b5d444-bda2-4d0a-8dee-06077ab73f18"
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IM退款自助化-不可发起场景交互修正</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #f0f2f5; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
        .phone-mockup { width: 375px; height: 750px; background: #ededed; display: flex; flex-direction: column; overflow: hidden; border: 8px solid #333; border-radius: 36px; box-shadow: 0 20px 50px rgba(0,0,0,0.15); }
        .chat-area { flex: 1; padding: 12px; overflow-y: auto; scrollbar-width: none; }
        .chat-area::-webkit-scrollbar { display: none; }
        .card-shadow { box-shadow: 0 2px 12px rgba(0,0,0,0.08); }
        .btn-active:active { opacity: 0.8; transform: scale(0.96); }
        
        /* 房东端镜像：保持颜色一致但不可点击 */
        .host-mirror-no-action { pointer-events: none; }
    </style>
</head>
<body class="p-8">

    <div class="max-w-6xl mx-auto flex flex-wrap justify-center gap-12">
        
        <!-- ================= 房客端 (Guest) ================= -->
        <div class="flex flex-col items-center">
            <h2 class="mb-4 text-lg font-bold text-gray-700 flex items-center leading-tight">
                <span class="w-3 h-3 bg-blue-500 rounded-full mr-2"></span> 房客端视角
            </h2>
            <div class="phone-mockup relative bg-[#ededed]">
                <!-- Header -->
                <div class="bg-[#f7f7f7] p-4 flex items-center border-b border-gray-200">
                    <div class="w-7 h-7 bg-blue-500 rounded-full mr-2 flex items-center justify-center text-[10px] text-white font-bold">房东</div>
                    <div class="font-bold text-gray-800 text-xs">美团民宿房东</div>
                </div>

                <div class="chat-area">
                    <div class="flex justify-end mb-4">
                        <div class="bg-[#ffda00] text-gray-800 p-2.5 rounded-2xl rounded-tr-none max-w-[75%] text-[13px]">临时去不了了，能退吗？</div>
                        <div class="w-7 h-7 bg-orange-400 rounded-full ml-2 flex items-center justify-center text-[10px] text-white font-bold flex-shrink-0 text-center leading-none">客</div>
                    </div>

                    <!-- 1. 政策卡片 (增加“坚持取消”按钮) -->
                    <div class="flex justify-start mb-3">
                        <div class="w-7 h-7 bg-white border border-gray-100 rounded-full mr-2 flex items-center justify-center text-[10px] text-[#ffb400] font-extrabold flex-shrink-0 card-shadow">美</div>
                        <div class="bg-white rounded-2xl w-[280px] card-shadow border border-gray-100 overflow-hidden">
                            <div class="p-3 flex bg-gray-50/50 border-b border-gray-50">
                                <div class="w-14 h-14 bg-gray-200 rounded-lg flex-shrink-0 overflow-hidden">
                                    <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=200&h=200&fit=crop" class="w-full h-full object-cover">
                                </div>
                                <div class="ml-2.5 flex-1 flex flex-col justify-center">
                                    <div class="font-bold text-[12px] text-gray-800 truncate">釜子锅的测试房</div>
                                    <div class="text-[10px] text-gray-500 mt-0.5">10.10－10.15 | ¥139</div>
                                </div>
                            </div>
                            <div class="p-3 text-left">
                                <div class="mb-2">
                                    <div class="text-red-500 font-bold text-[13px]">不可取消</div>
                                    <p class="text-[10px] text-gray-400 mt-0.5">取消将扣除全额房费 <span class="text-blue-500">详情 ></span></p>
                                </div>
                                <div class="bg-blue-50/50 p-2 rounded-lg border border-blue-100/30 text-blue-800 text-[10px] leading-relaxed italic mb-3">
                                    💡 温馨提示：房东已为您预留好房间，建议您按计划入住。
                                </div>
                                <div class="space-y-2">
                                    <button class="w-full bg-[#ffda00] py-2 rounded-lg text-[12px] font-bold btn-active">继续入住</button>
                                    <!-- 新增按钮 -->
                                    <button class="w-full bg-white border border-gray-200 text-gray-400 py-2 rounded-lg text-[12px] font-bold btn-active">坚持取消</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 2. 协商退小助手 (保持原样) -->
                    <div class="flex justify-start mb-4">
                        <div class="w-7 h-7 bg-transparent mr-2 flex-shrink-0"></div>
                        <div class="bg-white rounded-2xl w-[280px] p-3.5 card-shadow border border-blue-50 text-left">
                            <div class="flex items-center mb-1.5 text-blue-600">
                                <div class="bg-blue-500 rounded p-0.5 mr-1.5 flex items-center justify-center">
                                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"></path></svg>
                                </div>
                                <span class="text-[11px] font-bold">平台协商退小助手</span>
                            </div>
                            <p class="text-[10px] text-gray-500 mb-3 leading-relaxed">
                                若上述方案无法解决，您可以向房东友好协商。建议<span class="text-blue-600 font-bold">说明真实困难</span>，房东会尽快处理。
                            </p>
                            <div class="flex gap-2">
                                <button class="flex-1 border border-blue-100 bg-blue-50 text-blue-600 py-1.5 rounded-lg text-[10px] font-bold btn-active">电话联系</button>
                                <button class="flex-1 bg-blue-500 text-white py-1.5 rounded-lg text-[10px] font-bold btn-active shadow-sm shadow-blue-50">发送协商意向</button>
                            </div>
                        </div>
                    </div>

                    <!-- 3. 房客发送协商话术 (用户坚持后的结果) -->
                    <div class="flex justify-end mb-4">
                        <div class="bg-[#ffda00] text-gray-800 p-3 rounded-2xl rounded-tr-none max-w-[80%] text-[13px] leading-snug card-shadow text-left">
                            房东您好，我有特殊情况希望能协商退款，如您同意，请您发送<span class="font-bold underline">协商退款链接</span>给我，谢谢。
                        </div>
                        <div class="w-7 h-7 bg-orange-400 rounded-full ml-2 flex items-center justify-center text-[10px] text-white font-bold flex-shrink-0 text-center leading-none">客</div>
                    </div>
                </div>

                <!-- Footer -->
                <div class="bg-white p-3 pb-8 border-t border-gray-200">
                    <div class="bg-gray-100 h-9 rounded-full px-4 flex items-center text-gray-400 text-sm">请输入...</div>
                </div>
            </div>
        </div>

        <!-- ================= 房东端 (Host) ================= -->
        <div class="flex flex-col items-center">
            <h2 class="mb-4 text-lg font-bold text-gray-700 flex items-center leading-tight">
                <span class="w-3 h-3 bg-orange-500 rounded-full mr-2"></span> 房东端视角
            </h2>
            <div class="phone-mockup relative">
                <!-- Header -->
                <div class="bg-[#f7f7f7] p-4 flex items-center border-b border-gray-200">
                    <div class="w-7 h-7 bg-orange-400 rounded-full mr-2 flex items-center justify-center text-[10px] text-white font-bold flex-shrink-0 text-center leading-none">客</div>
                    <div class="font-bold text-gray-800 text-xs">美团民宿房客</div>
                </div>

                <div class="chat-area">
                    <!-- 房客咨询 -->
                    <div class="flex justify-start mb-4">
                        <div class="w-7 h-7 bg-orange-400 rounded-full mr-2 flex items-center justify-center text-[10px] text-white font-bold flex-shrink-0 text-center leading-none">客</div>
                        <div class="bg-white text-gray-800 p-2.5 rounded-2xl rounded-tl-none max-w-[75%] text-[13px] shadow-sm italic text-left leading-relaxed">临时去不了了，能退吗？</div>
                    </div>

                    <!-- 1. 政策卡片镜像 (移除按钮，无“坚持取消”) -->
                    <div class="flex justify-end mb-3">
                        <div class="bg-white rounded-2xl w-[280px] card-shadow border border-gray-100 overflow-hidden host-mirror-no-action mr-2 text-left">
                            <div class="p-3 flex bg-gray-50/50 border-b border-gray-50">
                                <div class="w-14 h-14 bg-gray-200 rounded-lg flex-shrink-0 overflow-hidden">
                                    <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=200&h=200&fit=crop" class="w-full h-full object-cover">
                                </div>
                                <div class="ml-2.5 flex-1 flex flex-col justify-center">
                                    <div class="font-bold text-[12px] text-gray-800 truncate">釜子锅的测试房</div>
                                    <div class="text-[10px] text-gray-500 mt-0.5">10.10－10.15 | ¥139</div>
                                </div>
                            </div>
                            <div class="p-3">
                                <div class="mb-2">
                                    <div class="text-red-500 font-bold text-[13px]">不可取消</div>
                                    <p class="text-[10px] text-gray-400 mt-0.5">取消将扣除全额房费 <span class="text-blue-500">详情 ></span></p>
                                </div>
                                <div class="bg-blue-50/50 p-2 rounded-lg border border-blue-100/30 text-blue-800 text-[10px] leading-relaxed italic">
                                    💡 温馨提示：房东已为您预留好房间，建议您按计划入住。
                                </div>
                            </div>
                        </div>
                        <div class="w-7 h-7 bg-white border border-gray-100 rounded-full flex items-center justify-center text-[10px] text-[#ffb400] font-extrabold flex-shrink-0 card-shadow self-start">美</div>
                    </div>

                    <!-- 2. 协商小助手镜像 (无按钮) -->
                    <div class="flex justify-end mb-4">
                        <div class="bg-white rounded-2xl w-[280px] p-3.5 card-shadow border border-blue-50 host-mirror-no-action mr-2 text-left">
                            <div class="flex items-center mb-1.5 text-blue-600">
                                <div class="bg-blue-500 rounded p-0.5 mr-1.5 flex items-center justify-center">
                                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"></path></svg>
                                </div>
                                <span class="text-[11px] font-bold">平台协商退小助手</span>
                            </div>
                            <p class="text-[10px] text-gray-500 leading-relaxed">
                                若上述方案无法解决，您可以向房东友好协商。建议先<span class="text-blue-600 font-bold">说明真实困难</span>，房东会尽快处理。
                            </p>
                        </div>
                        <div class="w-7 h-7 bg-transparent mr-2 flex-shrink-0 invisible"></div>
                    </div>

                    <!-- 3. 房客协商话术展示 -->
                    <div class="flex justify-start mb-4">
                        <div class="w-7 h-7 bg-orange-400 rounded-full mr-2 flex items-center justify-center text-[10px] text-white font-bold flex-shrink-0 text-center leading-none">客</div>
                        <div class="bg-white text-gray-800 p-3 rounded-2xl rounded-tl-none max-w-[80%] text-[13px] leading-snug shadow-sm text-left">
                            房东您好，我有特殊情况希望能协商退款，如您同意，请您发送<span class="font-bold underline">协商退款链接</span>给我，谢谢。
                        </div>
                    </div>

                    <!-- 4. 房东侧协商工具卡片 (真实操作引导) -->
                    <div class="flex justify-end mb-4 text-left">
                        <div class="bg-white rounded-xl p-3.5 border border-blue-100 w-[260px] mr-2 shadow-sm">
                            <p class="text-[11px] text-gray-800 mb-1.5 font-bold">房客寻求协商</p>
                            <p class="text-[10px] text-gray-500 mb-3 leading-snug">您可以点击下方按钮，向房客下发协商退款单：</p>
                            <button class="w-full bg-blue-500 text-white py-2 rounded-lg text-[12px] font-bold shadow-md shadow-blue-50 active:opacity-90">
                                发送“协商退款单”
                            </button>
                        </div>
                        <div class="w-7 h-7 bg-white border border-gray-100 rounded-full flex items-center justify-center text-[10px] text-[#ffb400] font-extrabold flex-shrink-0 card-shadow self-start">美</div>
                    </div>
                </div>

                <!-- Footer -->
                <div class="bg-white p-3 pb-8 border-t border-gray-200 flex items-center">
                    <div class="w-7 h-7 bg-gray-100 rounded-full flex items-center justify-center text-gray-400 mr-2 font-bold">+</div>
                    <div class="flex-1 bg-gray-100 h-9 rounded-full px-4 flex items-center text-gray-400 text-sm text-left">回复房客...</div>
                </div>
            </div>
        </div>

    </div>

</body>
</html>
```

