                                    <button class="w-full bg-[#ffda00] py-2 rounded-xl text-[12px] font-bold btn-active">继续入住</button>
                                    <button class="w-full bg-white border border-gray-300 text-gray-500 py-2 rounded-xl text-[12px] font-medium btn-active">坚持取消</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 2. 平台协商退小助手卡片 (房客侧：助手发，靠左) -->
                    <div class="flex justify-start mb-4 text-left animate-pop">
                        <div class="w-7 h-7 bg-white border border-gray-200 rounded-full mr-2 flex items-center justify-center text-[10px] text-orange-500 font-extrabold flex-shrink-0">美</div>
                        <div class="bg-white rounded-2xl w-[290px] p-4 card-shadow border border-blue-50">
                            <div class="flex items-center mb-2">
                                <div class="bg-blue-500 rounded p-0.5 mr-2">
                                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"></path></svg>
                                </div>
                                <span class="text-[12px] font-bold text-gray-800 tracking-tight">平台协商退小助手</span>
                            </div>
                            <p class="text-[11px] text-gray-500 mb-4 leading-relaxed">
                                您可以向房东说明情况请求协商退款。需勾选<span class="text-blue-600 font-bold">“与房东协商退款”</span>并提供原因。
                            </p>
                            <div class="flex gap-2">
                                <button class="flex-1 border border-blue-100 bg-blue-50 text-blue-600 py-2 rounded-xl text-[11px] font-bold btn-active">电话联系</button>
                                <button class="flex-1 bg-blue-500 text-white py-2 rounded-xl text-[11px] font-bold btn-active">发送意向</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Footer -->
                <div class="bg-white p-3 pb-8 border-t border-gray-200">
                    <div class="bg-gray-100 h-9 rounded-full px-4 flex items-center text-gray-400 text-sm">请输入...</div>
                </div>
            </div>
        </div>

        <!-- ================= 房东端 (Host) ================= -->
        <div class="flex flex-col items-center">
            <div class="flex items-center mb-4 space-x-2 font-bold text-gray-700 text-sm">
                <span class="w-2.5 h-2.5 bg-orange-500 rounded-full"></span>
                <span>房东端 (Host View)</span>
            </div>
            <div class="phone-mockup relative text-left">
                <!-- Header -->
                <div class="bg-[#f7f7f7] p-4 flex items-center border-b border-gray-200">
                    <div class="w-7 h-7 bg-orange-400 rounded-full mr-2 flex items-center justify-center text-[10px] text-white font-bold text-center leading-none flex-shrink-0">客</div>
                    <div class="font-bold text-gray-800 text-xs">美团民宿房客</div>
                </div>

                <div class="chat-area flex flex-col">
                    <!-- 房客咨询 (在房东端：靠左) -->
                    <div class="flex justify-start mb-4">
                        <div class="w-7 h-7 bg-orange-400 rounded-full mr-2 flex items-center justify-center text-[10px] text-white font-bold flex-shrink-0 text-center leading-none">客</div>
                        <div class="bg-white text-gray-800 p-2.5 rounded-2xl rounded-tl-none max-w-[75%] text-[13px] shadow-sm italic text-left leading-relaxed">临时去不成了，能全退吗</div>
                    </div>

                    <!-- 1. 镜像政策卡片 (房东端：助手发，靠右，样式完全同步房客侧) -->
                    <div class="flex justify-end mb-4 text-left">
                        <div class="bg-white rounded-2xl w-[290px] card-shadow border border-gray-100 overflow-hidden pointer-events-none">
                            <div class="p-3 flex bg-gray-50/50 border-b border-gray-50">
                                <div class="w-14 h-14 bg-gray-200 rounded-lg flex-shrink-0 overflow-hidden">
                                    <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=200&h=200&fit=crop" class="w-full h-full object-cover">
                                </div>
                                <div class="ml-3 flex-1 flex flex-col justify-center">
                                    <div class="font-bold text-[12px] text-gray-800 truncate mb-0.5">釜子锅的测试房</div>
                                    <div class="text-[10px] text-gray-500">10.10－10.15 | 合计 ¥139</div>
                                </div>
                            </div>
                            <div class="p-3.5">
                                <div class="flex justify-between items-start mb-3">
                                    <div class="text-left leading-tight">
                                        <div class="text-red-500 font-bold text-[14px]">不可取消</div>
                                        <p class="text-[9px] text-gray-400 mt-0.5 font-medium">取消将扣除全额房费 <span class="text-blue-500">详情 ></span></p>
                                    </div>
                                    <div class="text-red-500 font-bold text-[14px]">¥139.00</div>
                                </div>
                                <div class="bg-blue-50/60 p-2.5 rounded-xl border border-blue-100/50 text-blue-800 text-[10px] leading-relaxed mb-4">
                                    💡 温馨提示：房间已为您预留，建议您按原计划入住，不负旅途好时光。
                                </div>
                                <div class="flex flex-col gap-2">
                                    <button class="w-full bg-[#ffda00] py-2 rounded-xl text-[12px] font-bold opacity-60">继续入住</button>
                                    <button class="w-full bg-white border border-gray-300 text-gray-500 py-2 rounded-xl text-[12px] font-medium opacity-60">坚持取消</button>
                                </div>
                            </div>
                        </div>
                        <!-- 美团助手头像在右侧 -->
                        <div class="w-7 h-7 bg-white border border-gray-200 rounded-full ml-2 flex items-center justify-center text-[10px] text-orange-500 font-extrabold flex-shrink-0">美</div>
                    </div>

                    <!-- 2. 镜像小助手引导 (房东端：助手发，靠右，样式完全同步房客侧) -->
                    <div class="flex justify-end mb-4 text-left">
                        <div class="bg-white rounded-2xl w-[290px] p-4 card-shadow border border-blue-50 pointer-events-none">
                            <div class="flex items-center mb-2">
                                <div class="bg-blue-500 rounded p-0.5 mr-2">
                                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a11 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"></path></svg>
                                </div>
                                <span class="text-[12px] font-bold text-gray-800 tracking-tight">平台协商退小助手</span>
                            </div>
                            <p class="text-[11px] text-gray-500 mb-4 leading-relaxed">
                                您可以向房东说明情况请求协商退款。需勾选<span class="text-blue-600 font-bold">“与房东协商退款”</span>并提供原因。
                            </p>
                            <div class="flex gap-2">
                                <button class="flex-1 border border-blue-100 bg-blue-50 text-blue-600 py-2 rounded-xl text-[11px] font-bold opacity-60">电话联系</button>
                                <button class="flex-1 bg-blue-500 text-white py-2 rounded-xl text-[11px] font-bold opacity-60">发送意向</button>
                            </div>
                        </div>
                        <!-- 美团助手头像在右侧 -->
                        <div class="w-7 h-7 bg-white border border-gray-200 rounded-full ml-2 flex items-center justify-center text-[10px] text-orange-500 font-extrabold flex-shrink-0">美</div>
                    </div>

                    
                </div>
                
                <!-- Footer -->
                <div class="bg-white p-3 pb-8 border-t border-gray-200 flex items-center">
                    <div class="w-7 h-7 bg-gray-100 rounded-full flex items-center justify-center text-gray-400 mr-2 font-bold">+</div>
                    <div class="flex-1 bg-gray-100 h-9 rounded-full px-4 flex items-center text-gray-400 text-xs italic">回复房客...</div>
                </div>
            </div>
        </div>

    </div>

</body>
</html>
```

