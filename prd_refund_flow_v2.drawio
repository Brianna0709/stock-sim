          <mxGeometry x="975" y="220" width="150" height="80" as="geometry" />
        </mxCell>
        <mxCell id="e_start_intent" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="start" target="intent" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== 三大意图分支 ===== -->

        <!-- 意图A：退款退订 -->
        <mxCell id="intentA" value="退款 / 退订 / 取消" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="370" width="180" height="55" as="geometry" />
